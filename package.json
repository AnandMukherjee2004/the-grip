{
  "name": "thegrip-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:web": "bunx next dev",
    "dev:api": "bun run --hot server/index.ts",
    "build": "bunx next build",
    "start": "bunx next start",
    "start:api": "bun run server/index.ts",
    "lint": "bunx eslint",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.11.4",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
